<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme. -->
    <style name="Theme.WorkScheduler" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Main Palette -->
        <item name="colorPrimary">@color/accent_purple</item>
        <item name="colorSecondary">@color/accent_teal</item>

        <!-- Semantic Colors Mapping (Dark Default) -->
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:textColorPrimary">@color/text_primary_dark</item>
        <item name="android:textColorSecondary">@color/text_secondary_dark</item>

        <item name="materialCardViewStyle">@style/CustomCardStyle</item>
    </style>

    <!-- Theme for Light Mode -->
    <style name="Theme.WorkScheduler.Light" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/accent_purple</item>
        <item name="colorSecondary">@color/accent_teal</item>

        <!-- Semantic Colors Mapping -->
        <item name="android:windowBackground">@color/bg_light</item>
        <item name="android:textColorPrimary">@color/text_primary_light</item>
        <item name="android:textColorSecondary">@color/text_secondary_light</item>

        <item name="materialCardViewStyle">@style/CustomCardStyle.Light</item>
    </style>

    <style name="CustomCardStyle" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">0dp</item>
        <item name="cardBackgroundColor">@color/surface_dark</item>
        <item name="strokeColor">@color/stroke_dark</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="CustomCardStyle.Light" parent="CustomCardStyle">
        <item name="cardBackgroundColor">@color/surface_light</item>
        <item name="strokeColor">@color/stroke_light</item>
        <item name="cardElevation">2dp</item>
    </style>

    <style name="ModernChip" parent="Widget.MaterialComponents.Chip.Filter">
        <item name="chipCornerRadius">12dp</item>
        <item name="chipBackgroundColor">@color/stroke_dark</item>
        <item name="android:textColor">@color/text_primary_dark</item>
        <item name="checkedIconVisible">false</item>
        <item name="chipStrokeWidth">0dp</item>
    </style>

    <style name="CustomTimePickerTheme" parent="ThemeOverlay.MaterialComponents.TimePicker">
        <item name="colorPrimary">@color/accent_purple</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnSurface">@color/white</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:windowBackground">@android:color/transparent</item>
    </style>
</resources>
